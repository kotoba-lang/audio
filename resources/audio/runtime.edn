{:contract/id :kotoba.audio/game-runtime
 :contract/version 1
 :runtime :cljc
 :buses [:master :music :sfx :voice :ambient :ui]
 :gain {:range [0.0 1.0] :composition [:master :bus :duck :source]}
 :mute {:scope #{:master :bus}}
 :ducking {:reasons #{:voice :ui-modal}
           :host-ramp [:attack-ms :release-ms]}
 :scene {:music :single-cue :ambient :loop-set
         :transition {:crossfade true :host-clock true}}
 :spatial {:listener true :source-position true :rolloff true
           :voice-limit :priority}
 :host-responsibilities #{:audio-device :clock :decode :buffer-cache :web-audio-autoplay}}
